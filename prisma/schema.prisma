enum ClassMeetingStatus {
  SCHEDULED
  COMPLETED
  NO_SHOW
  CANCELLED
}

// คาบเรียนที่เกิดขึ้นจริง 1 ครั้ง (ใช้ร่วมกันได้หลายคนสำหรับ Group)
model ClassMeeting {
  id          String             @id @default(cuid())
  courseId    String
  teacherId   String?
  scheduledAt DateTime
  durationMin Int                @default(60)
  meetingLink String?
  status      ClassMeetingStatus @default(SCHEDULED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course      Course            @relation(fields: [courseId], references: [id])
  teacher     Teacher?          @relation(fields: [teacherId], references: [id])
  attendances ClassAttendance[]

  @@index([courseId])
  @@index([teacherId])
  @@index([scheduledAt])
}

// การเข้าเรียนของนักเรียนแต่ละคนต่อ 1 คาบ
model ClassAttendance {
  id             String           @id @default(cuid())
  classMeetingId String
  enrollmentId   String
  studentId      String
  status         AttendanceStatus @default(SCHEDULED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  classMeeting ClassMeeting @relation(fields: [classMeetingId], references: [id])
  enrollment   Enrollment   @relation(fields: [enrollmentId], references: [id])
  student      Student      @relation(fields: [studentId], references: [id])

  @@unique([classMeetingId, studentId])
  @@index([enrollmentId])
  @@index([studentId])
}

enum AttendanceStatus {
  SCHEDULED
  ATTENDED
  NO_SHOW
  CANCELLED
}
